# 99-cloudplay-uinput.rules — grant the `input` group access to /dev/uinput
# so the xemu backend's Phase-5 VirtualPad can create virtual gamepads from
# inside the rootless cloudplay-dev / cloudplay podman containers.
#
# Install on moon:
#   sudo cp systemd/99-cloudplay-uinput.rules /etc/udev/rules.d/
#   sudo udevadm control --reload
#   sudo udevadm trigger /dev/uinput
#   sudo usermod -aG input rocks   # one-time, then re-login
#
# The `input` group comes pre-created on modern Linux distros (typically
# gid 104 or 996). The container's quadlet already does GroupAdd=input so
# supplementary-group membership flows through the user namespace.

KERNEL=="uinput", MODE="0660", GROUP="input", TAG+="uaccess"

# Event nodes created by our virtual pads must be world-accessible so the
# rootless podman container (which does not share the host's input-group GID
# mapping) can open them via its xemu SDL joystick scan. Scope is narrowed to
# nodes whose parent carries exactly our virtual pad's name/vid/pid — a real
# physical 360 pad on the host does NOT match because its parent attrs include
# a non-empty phys/uniq chain the virtual device lacks.
SUBSYSTEM=="input", ATTRS{name}=="Microsoft X-Box 360 pad", ATTRS{id/vendor}=="045e", ATTRS{id/product}=="028e", ATTRS{phys}=="", MODE="0666", TAG+="uaccess"
SUBSYSTEM=="input", ATTRS{name}=="cloudplay-canary-pad",    MODE="0666", TAG+="uaccess"
