[Unit]
Description=Cloudplay — games.milvenan.technology
Wants=network-online.target
After=network-online.target

[Container]
ContainerName=cloudplay
Image=localhost/cloudplay-run:latest

# libretro cores + NVIDIA userspace need the default container sandbox relaxed.
# --group-add keep-groups propagates the rootless user's supplementary groups
# into the namespace; --group-add 104 explicitly joins the host's `input`
# group so the container can open kernel-owned /dev/input/event* nodes
# created via the xemu backend's uinput virtual pads. (/etc/subgid on moon
# includes `rocks:104:1` so this GID is mappable.)
SecurityLabelDisable=true
PodmanArgs=--security-opt seccomp=unconfined --group-add 104

# GPU + display passthrough
AddDevice=/dev/dri
AddDevice=nvidia.com/gpu=all
# /dev/uinput for the xemu backend's virtual Xbox 360 gamepad. Harmless
# when xemu is disabled; required the moment xbox games are enabled.
# See systemd/99-cloudplay-uinput.rules for the host-side udev setup.
AddDevice=/dev/uinput
# /dev/input/ event nodes need to be visible so xemu's SDL can find our
# virtual pad (AddDevice only exposes specific nodes — we can't predict
# which /dev/input/eventN udev will assign).
Volume=/dev/input:/dev/input

# External-facing ports
PublishPort=0.0.0.0:8009:8000/tcp
PublishPort=0.0.0.0:9753:9753/udp

# Source tree (read-only, bind-mounted so rsync deploys skip a rebuild)
Volume=/home/rocks/containers/cloudplay/config/config.yaml:/usr/local/share/cloud-game/config.yaml:ro,z
Volume=/home/rocks/containers/cloudplay/web:/usr/local/share/cloud-game/web:ro,z

# Game library
# Game library. Writable because pkg/worker/romcache extracts .7z
# archives in place on first play and removes the original archive once
# the extracted file is durable. A ro mount would make the hydrator
# fail on any archived ROM.
Volume=/var/mnt/data/media/games:/usr/local/share/cloud-game/assets/games:rw
Volume=/home/rocks/containers/cloudplay/cores:/usr/local/share/cloud-game/assets/cores:ro,z

# Runtime state (read-write)
Volume=/home/rocks/containers/cloudplay/saves:/root/.cr/save:z
Volume=/home/rocks/containers/cloudplay/libretro/system:/usr/local/share/cloud-game/libretro/system:z
Volume=/home/rocks/containers/cloudplay/libretro/saves:/usr/local/share/cloud-game/libretro-save:z
# IGDB credentials — bind-mounted read-only from the host so they
# never live in the repo. File contains CLOUD_GAME_IGDB_CLIENT_ID and
# CLOUD_GAME_IGDB_CLIENT_SECRET; path matches config.yaml's
# igdb.credentialsFile. 0600 on the host side.
Volume=/home/rocks/containers/cloudplay/secrets:/secrets:ro,z

# xemu BIOS (MCPX + flash) + HDD qcow2. Must be rw because xemu writes
# back to the qcow2 for save games, eeprom, dashboard settings. Empty
# dir + xemu.enabled=false (config.yaml default) is fine — only the
# xemu backend touches this path. Operators populating the dir signal
# their intent to turn on xbox support by also flipping xemu.enabled.
Volume=/home/rocks/containers/cloudplay/xemu-bios:/xemu-bios:z

# flycast BIOS (dc_boot.bin + dc_flash.bin). Optional for most DC titles
# — flycast synthesizes an HLE bootrom when biosPath is unset — but
# required for Seaman and a handful of others that poke at the real
# BIOS. Empty dir + flycast.enabled=false (config.yaml default) is fine;
# populating it signals intent to flip flycast.enabled=true and the
# adapter will bind Dreamcast.HLE_BIOS=no in emu.cfg.
Volume=/home/rocks/containers/cloudplay/flycast-bios:/flycast-bios:z

# Vulkan ICDs + NVIDIA userspace libs from host
Volume=/usr/share/vulkan/icd.d:/usr/share/vulkan/icd.d:ro

# Display / driver / encode environment
Environment=DISPLAY=:99
Environment=MESA_GL_VERSION_OVERRIDE=4.5
Environment=NVIDIA_DRIVER_CAPABILITIES=all
Environment=LD_LIBRARY_PATH=/lib64:/usr/lib64:/usr/lib:/lib
Environment=__GLX_VENDOR_LIBRARY_NAME=nvidia
Environment=CLOUDPLAY_FRAME_TIMING=1
Environment=CLOUDPLAY_GL_BACKEND=egl

# Cloud-game knobs
Environment=CLOUD_GAME_ENCODER_VIDEO_CODEC=h264_nvenc
Environment=CLOUD_GAME_ENCODER_VIDEO_ZEROCOPY=true
Environment=CLOUD_GAME_WEBRTC_SINGLEPORT=9753
Environment=CLOUD_GAME_WEBRTC_ICELITE=true
Environment=CLOUD_GAME_WEBRTC_ICEIPMAP=107.143.179.17
Environment=CLOUD_GAME_WORKER_NETWORK_PUBLICADDRESS=107.143.179.17
Environment=CLOUD_GAME_COORDINATOR_SERVER_CACHECONTROL=no-store
Environment=CLOUD_GAME_COORDINATOR_DEBUG=true
Environment=CLOUD_GAME_WORKER_DEBUG=true

[Service]
Restart=always
TimeoutStopSec=70

[Install]
WantedBy=default.target
